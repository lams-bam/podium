<!-- Selected Program Details (Centered) -->
<div style="background-color:#f7f7f7; border-radius:8px; padding:18px 20px; margin:24px auto; max-width:480px; font-family: Arial, Helvetica, sans-serif; color:#222; line-height:1.45; text-align:center;">

  <div style="font-weight:700; margin-bottom:8px;">Your Selected Program Details:</div>

  {{#if track}}
    <p style="margin:0;">🎯 <strong>Track:</strong> {{track}}</p>
  {{/if}}

  {{#if liveLab}}
    <p style="margin:0;">📅 <strong>LiveLab:</strong> {{liveLab}}</p>
  {{/if}}

  {{#if codes}}
    <p style="margin:0;">📚 <strong>Course Codes:</strong> {{codes}}</p>
  {{/if}}

  {{#unless track}}
    {{#unless liveLab}}
      {{#unless codes}}
        <p style="margin:0;">⚪ No selections yet. You can update them 
          <a href="https://www.podiumeducation.com" target="_blank" style="color:#0b61a4; text-decoration:underline;">here</a>.
        </p>
      {{/unless}}
    {{/unless}}
  {{/unless}}

</div>

