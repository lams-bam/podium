<div style="font-family: Arial, Helvetica, sans-serif; font-size:16px; line-height:24px; mso-line-height-rule:exactly; color:#000000;">

  <ol style="margin:0; padding-left:20px; font-family: Arial, Helvetica, sans-serif; font-size:16px; line-height:24px; mso-line-height-rule:exactly;">

    <!-- STEP 1 -->
    <li style="margin:0 0 16px 0; font-weight:700;">
      Log in to {{{ snippet "Product - CDE - LMS Name" }}} for {{{ snippet "Program - CDE - Name" }}}.

      <div style="margin-top:8px; font-weight:400; line-height:24px; mso-line-height-rule:exactly;">

        <div style="margin-top:6px;">
          → Your login email is:<br/>
          <strong>{{email}}</strong>
        </div>

        <div style="margin-top:20px;">
          {{{ snippet "Email - CTA - Programs - Login - CDE" }}}
        </div>

      </div>
    </li>

    <!-- STEP 2 -->
    <li style="margin:0 0 16px 0;">
      <strong>Explore {{{ snippet "Product - CDE - LMS Name" }}}</strong> &amp; check out your course materials!

      <div style="margin-top:8px; font-weight:400; line-height:24px; mso-line-height-rule:exactly;">

        <!-- Checklist -->
        <ul style="margin:12px 0 0 0; padding-left:0; list-style:none;">
      
          <li style="margin:0 0 10px 0;">
            ☐ Start with <i>{{{ snippet "Product - CDE - Module 1" }}}</i> and try to finish before your first {{#ifEq is_live_session_not_livelab "true"}}{{{ snippet "Product - CDE - School Synchronous Session" }}}{{else}}{{{ snippet "Product - CDE - Synchronous Session" }}}{{/ifEq}}.
          </li>
        </ul>

        <div style="margin-top:12px;">
          💡 <strong>Pro Tip:</strong>
          Take the {{{ snippet "Product - CDE - LMS Name" }}} Tour when you first log in! Click the {{{ snippet "Product - CDE - Student Chatbot Icon" }}} icon on the bottom-right corner of {{{ snippet "Product - CDE - LMS Name" }}} for tips, tools, and chat with your dedicated support team.
        </div>

      </div>
    </li>

    <!-- STEP 3 -->
    <li style="margin:0; font-weight:700;">
      Join the first {{#ifEq is_live_session_not_livelab "true"}}{{{ snippet "Product - CDE - School Synchronous Session" }}}{{else}}{{{ snippet "Product - CDE - Synchronous Session" }}}{{/ifEq}} on
      {{#if v_firstLiveLabTime}}
        {{{ dateFormat v_firstLiveLabTime format="EEEE, MMMM d, YYYY' at 'h:mm aaa (z)" tz=timeZone }}}
      {{else}}
        (date/time coming soon)
      {{/if}}

      <div style="margin-top:8px; font-weight:400; line-height:24px; mso-line-height-rule:exactly;">

        <!-- Checklist -->
        <ul style="margin:12px 0 0 0; padding-left:0; list-style:none;">
          <li style="margin:0 0 10px 0;">
            ☐ Find the Zoom link on the
            <a href="https://hq.globaltech.org/calendar"
               target="_blank"
               style="color:#1a73e8; text-decoration:underline;">
              {{{ snippet "Product - CDE - Calendar" }}}
            </a> — just click the {{#ifEq is_live_session_not_livelab "true"}}{{{ snippet "Product - CDE - School Synchronous Session Calendar Event" }}}{{else}}{{{ snippet "Product - GCA - Synchronous Session - Emoji" }}} <strong>{{{ snippet "Product - GCA - Synchronous Session" }}}</strong>{{/ifEq}} event.
          </li>
          <li style="margin:0;">
            ☐ <strong>Register with the login email:</strong>
            <strong>{{email}}</strong>
            to be counted as present.
          </li>
        </ul>

        <div style="margin-top:12px;">
          <strong>Note:</strong>
          {{#ifEq is_live_session_not_livelab "true"}}Live Sessions and{{else}}{{/ifEq}}
{{{ snippet "Product - CDE - Synchronous Session" }}}s are part of your {{lower (snippet "Product - CDE - Grade")}}.
        </div>

      </div>
    </li>

    <!-- Late Start Note -->
    {{#ifEq is_late_start "true"}}
      <div style="margin-top:14px; font-weight:400; line-height:24px; mso-line-height-rule:exactly;">
        Since your home university's term starts after the first {{{ snippet "Product - CDE - Synchronous Session" }}}, the first session will be optional for you. Feel free to join live or catch up with the recording.
      </div>
    {{/ifEq}}

  </ol>

</div>
