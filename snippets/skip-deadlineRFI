{{#if override_skip}}{{else}}
    {{#assign "system_deadlineSkipActive"}}{{{ snippet "system - disable deadline send skip" }}}{{/assign}}
    {{#ifMatchesRegexStr system_deadlineSkipActive "True"}}{{#if deadlineProgramRegistrationClose}}{{#ifMatchesRegexStr email ".*podiumeducation.com"}}{{else}}
        {{#each allOpportunities}}
            {{#ifEq Opportunityid id}}
                {{#ifLt (dateFormat deadlineProgramRegistrationClose format="yyyyMMdd" tz="UTC") (dateMath "now" "+7d" format="yyyyMMdd" tz="UTC")}}
                    {{sendSkip cause="deadline passed"}}
                {{/ifLt}}
            {{/ifEq}}
        {{/each}}
    
    {{#assign "eval_regCloseDateSchoolParameters1"}}
    {{#ifMatchesRegexStr v_registrationMethod "Student Self Registers.*"}}
        {{#ifMatchesRegexStr v_liveLabRequirement "Not Required Before Registration"}}
            {{#ifMatchesRegexStr v_stage ".*(Application Complete|LiveLab Submit).*"}}
                True
            {{/ifMatchesRegexStr}}
        {{/ifMatchesRegexStr}}
    {{/ifMatchesRegexStr}}
    {{/assign}}
    
    {{#assign "eval_regCloseDateSchoolParameters2"}}
    {{#ifMatchesRegexStr v_registrationMethod "Student Self Registers.*"}}
        {{#ifMatchesRegexStr v_liveLabRequirement "Required Before Registration"}}
            {{#ifMatchesRegexStr v_stage "LiveLab Selected"}}
                True
            {{/ifMatchesRegexStr}}
        {{/ifMatchesRegexStr}}
    {{/ifMatchesRegexStr}}
    {{/assign}}
    
    {{#or eval_regCloseDateSchoolParameters1 eval_regCloseDateSchoolParameters2}}{{else}}{{sendSkip cause="not applicable school"}}{{/or}}
    {{/ifMatchesRegexStr}}{{/if}}{{/ifMatchesRegexStr}}
{{/if}}